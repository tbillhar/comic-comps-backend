{
  "title": "Comic Comps eBay Sold Search",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "query": {
      "title": "Query",
      "type": "string",
      "description": "eBay sold/completed search query.",
      "editor": "textfield"
    },
    "maxResults": {
      "title": "Max Results",
      "type": "integer",
      "description": "Maximum number of sold rows to emit.",
      "editor": "number",
      "default": 50,
      "minimum": 1,
      "maximum": 200
    },
    "daysToScrape": {
      "title": "Days To Scrape",
      "type": "integer",
      "description": "Unused by the actor URL directly, but retained for backend compatibility.",
      "editor": "number",
      "default": 90,
      "minimum": 1,
      "maximum": 365
    },
    "ebaySite": {
      "title": "eBay Site",
      "type": "string",
      "description": "eBay domain, for example ebay.com.",
      "editor": "textfield",
      "default": "ebay.com"
    },
    "currency": {
      "title": "Currency",
      "type": "string",
      "description": "Currency hint for downstream consumers.",
      "editor": "textfield",
      "default": "USD"
    },
    "useApifyProxy": {
      "title": "Use Apify Proxy",
      "type": "boolean",
      "description": "Use Apify Proxy for the actor run. Recommended for eBay.",
      "editor": "checkbox",
      "default": true
    },
    "useResidentialProxy": {
      "title": "Use Residential Proxy",
      "type": "boolean",
      "description": "Prefer Apify residential proxies when Apify Proxy is enabled.",
      "editor": "checkbox",
      "default": true
    },
    "sort": {
      "title": "Sort",
      "type": "string",
      "description": "Result sort mode.",
      "editor": "select",
      "default": "endedRecently",
      "enum": [
        "endedRecently"
      ]
    }
  },
  "required": [
    "query"
  ]
}
